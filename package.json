{
  "name": "my-account-book-backend",
  "version": "0.1.0",
  "description": "Personal account-book backend with recurring transactions",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start:dev": "docker-compose --env-file .env.dev -f docker-compose-dev.yml up -d postgres redis && nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config jest.config.ts --testPathPattern=\"test/(unit|integration)\"",
    "test:unit": "jest --config jest.config.ts --testPathPattern=\"test/unit\"",
    "test:integration": "jest --config jest.config.ts --testPathPattern=\"test/integration\"",
    "test:e2e": "jest --config test/e2e/jest-e2e.json --forceExit",
    "typeorm": "ts-node -r tsconfig-paths/register node_modules/typeorm/cli.js -d src/config/typeorm.config.ts",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:run": "npm run typeorm migration:run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/config/typeorm.config.js",
    "migration:revert": "npm run typeorm migration:revert",
    "docker:dev": "docker-compose --env-file .env.dev -f docker-compose-dev.yml up -d",
    "docker:dev:down": "docker-compose --env-file .env.dev -f docker-compose-dev.yml down",
    "docker:dev:remove": "docker-compose --env-file .env.dev -f docker-compose-dev.yml down -v"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.2",
    "argon2": "^0.31.2",
    "async-mutex": "^0.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.10.1",
    "joi": "^17.13.4",
    "luxon": "^3.5.0",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
